# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Data (large files — use DVC or store externally) ──────────────────────────
data/raw/*.parquet
data/processed/*.parquet
data/processed/*.pkl

# ── Model weights (binary artifacts) ──────────────────────────────────────────
data/models/*.pkl
data/models/*.npz
data/models/*.pt
data/models/*.pth

# ── MLflow ────────────────────────────────────────────────────────────────────
mlflow.db
mlruns/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/
*.ipynb

# ── Outputs (regenerate by running the pipeline) ──────────────────────────────
outputs/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Secrets ───────────────────────────────────────────────────────────────────
*.pem
*.key
secrets/
